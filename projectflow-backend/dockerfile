# Multi-stage build for the Spring Boot backend

# 1) Build stage
FROM maven:3.10.1-eclipse-temurin-17 AS build
WORKDIR /workspace

# Copy maven metadata first for better caching
COPY pom.xml .
COPY src ./src

# Build the application (skip tests for faster iterations; remove -DskipTests for CI if you want tests run)
RUN mvn -B -DskipTests package

# 2) Runtime stage
FROM eclipse-temurin:17-jre
WORKDIR /app

# Copy the built jar from the build stage
COPY --from=build /workspace/target/*.jar app.jar

# Optional: allow runtime JVM options via JAVA_OPTS
ENV JAVA_OPTS="-Xms256m -Xmx512m"

EXPOSE 8080
ENTRYPOINT ["sh", "-c", "java $JAVA_OPTS -jar /app/app.jar"]
